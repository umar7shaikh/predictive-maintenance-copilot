# Copy to .env and fill in real values.

# --- Database (PostgreSQL 18 detected on port 5433) ---
DATABASE_URL=postgresql+psycopg://postgres:CHANGE_ME@localhost:5433/pdm_copilot

# --- Auth ---
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Groq LLM ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
# Set to true to bypass Groq and use a deterministic stub (useful with no key / rate limits)
LLM_STUB_MODE=false

# --- MLflow (local file store) ---
MLFLOW_TRACKING_URI=file:./mlruns
MLFLOW_EXPERIMENT=pdm-anomaly-detection

# --- RAG ---
CHROMA_DIR=./chroma_store
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Storage ---
UPLOAD_DIR=./uploads

# --- Anomaly detection defaults ---
ZSCORE_THRESHOLD=3.0
ROLLING_WINDOW=10

# --- CORS (frontend dev server) ---
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
